NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://dataclean:dataclean_dev@localhost:5432/dataclean?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth — rotate in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# OCR provider: mistral | textract | vision | azure | mock
OCR_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai/v1

# Encryption for stored integration credentials (32 bytes, hex)
API_ENCRYPTION_KEY=

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DataClean <noreply@dataclean.local>

# Logging
LOG_LEVEL=info

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=dataclean-backend

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limiting (requests per window per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
